# Copia este archivo a ".env.local" y rellena tus valores.
# .env.local NO se sube al repositorio (ver .gitignore).

# OAuth de Google (login REAL). Si NO los defines, el servidor usa una pantalla
# de inicio de sesión SIMULADA pensada solo para desarrollo/demo.
# Obtén estas credenciales en https://console.cloud.google.com (OAuth 2.0 Client ID).
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="MY_GOOGLE_CLIENT_SECRET"

# APP_URL: URL pública donde se hospeda la app.
# Se usa para links auto-referenciales, callbacks de OAuth y endpoints de la API.
APP_URL="MY_APP_URL"
