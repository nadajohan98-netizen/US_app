{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "email": { "type": "string", "description": "User email address" },
        "name": { "type": "string", "description": "User display name" },
        "avatar": { "type": "string", "description": "User avatar URL" },
        "birthday": { "type": "string", "description": "User birthday date (YYYY-MM-DD)" },
        "coupleId": {
          "type": "string",
          "description": "ID of the couple relationship this user belongs to"
        }
      },
      "required": ["uid", "email"]
    },
    "Couple": {
      "title": "Couple Relationship",
      "description": "Shared state and connection between two users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user1Email": { "type": "string" },
        "user2Email": { "type": "string" },
        "user1Name": { "type": "string" },
        "user2Name": { "type": "string" },
        "user1Avatar": { "type": "string" },
        "user2Avatar": { "type": "string" },
        "user1Birthday": { "type": "string" },
        "user2Birthday": { "type": "string" },
        "warmth": { "type": "number" },
        "streak": { "type": "number" },
        "linkedSpotifyUrl": { "type": "string" },
        "chatTheme": {
          "type": "string",
          "description": "Selected theme name for the telephone-like chat"
        },
        "commonItems": { "type": "array" }
      },
      "required": ["id", "user1Email"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Real-time message exchanged between a couple",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderEmail": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isAudio": { "type": "boolean" },
        "audioUrl": { "type": "string" },
        "audioDuration": { "type": "number" },
        "isPhoto": { "type": "boolean" },
        "photoUrl": { "type": "string" },
        "emoji": { "type": "string" },
        "seen": { "type": "boolean" }
      },
      "required": ["id", "senderEmail", "text"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User document mapped in firestore"
    },
    "couples/{coupleId}": {
      "schema": "Couple",
      "description": "Couple documents containing shared settings"
    },
    "couples/{coupleId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Subcollection of real-time messages for a couple"
    }
  }
}
